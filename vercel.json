{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npm run prebuild && next build --webpack",
  "git": {
    "deploymentEnabled": {
      "main": true,
      "feature/*": true
    }
  },
  "crons": [
    {
      "path": "/api/cron/cleanup-chats",
      "schedule": "0 3 * * *"
    }
  ]
}
