# Anthropic Claude API Key
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Vercel Blob Storage
# Auto-injected when you connect Vercel Blob to your project
# Find in Vercel Dashboard > Storage > Blob > Connect to Project
BLOB_READ_WRITE_TOKEN=

# Admin Portal Authentication
# For preview/development environments
ADMIN_PASSWORD_PREVIEW=
# JWT signing secret (generate with: openssl rand -base64 32)
JWT_SECRET=

# Optional: Google Search Console site verification
# Get from: https://search.google.com/search-console → Add property → HTML tag method
GOOGLE_SITE_VERIFICATION=

# Telegram lead notification (POST /api/v1/contact)
# Optional — if either var is absent, lead notifications are silently skipped and the form still returns 201.
# Bot token from @BotFather — create a bot, then copy the token it gives you
TELEGRAM_BOT_TOKEN=
# Your Telegram user ID (chat_id). Get it by messaging @userinfobot
TELEGRAM_NOTIFY_CHAT_ID=
